{
  "name": "WebdriverIO_Appium",
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@wdio/allure-reporter": "^9.27.2",
    "@wdio/appium-service": "^9.27.2",
    "@wdio/cli": "^9.27.2",
    "@wdio/globals": "^9.27.2",
    "@wdio/local-runner": "^9.27.2",
    "@wdio/mocha-framework": "^9.27.2",
    "@wdio/spec-reporter": "^9.27.2",
    "@wdio/visual-service": "^9.2.3",
    "allure-commandline": "^2.42.0",
    "appium-uiautomator2-driver": "^7.6.0",
    "expect-webdriverio": "^5.6.8",
    "wdio-wait-for": "^3.1.1"
  },
  "scripts": {
    "postinstall": "npx appium driver install uiautomator2 && npx appium driver install xcuitest || echo 'Drivers installation completed'",
    "test:android:bs": "wdio run ./config/wdio.conf.android.bs.ts",
    "test:android": "wdio run ./config/wdio.conf.android.ts",
    "allure:open": "npx allure open ./allure-report",
    "allure:serve": "npx allure serve ./reporters/allure-results",
    "allure:generate": "npx allure generate ./reporters/allure-results --clean -o ./allure-report",
    "allure:report": "npm run allure:generate && npm run allure:open",
    "typecheck": "tsc --noEmit"
  }
}
